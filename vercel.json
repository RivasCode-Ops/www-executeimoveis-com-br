{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "name": "execute-imoveis-site",
  "buildCommand": "npm run build",
  "outputDirectory": "out",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/*.ts": {
      "runtime": "@vercel/node"
    }
  }
}
